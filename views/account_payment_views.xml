<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_internal_transfer" model="ir.ui.view">
        <field name="name">account.payment.form.internal.transfer</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_type']" position="before">
                <field name="is_internal_transfer"/>
            </xpath>

            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="destination_journal_id"
                       invisible="not is_internal_transfer"
                       required="is_internal_transfer"
                       options="{'no_create': True, 'no_open': True}"/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">is_internal_transfer</attribute>
                <attribute name="required">not is_internal_transfer</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_bank_id']" position="attributes">
                <attribute name="invisible">is_internal_transfer</attribute>
            </xpath>
        </field>
    </record>
</odoo>
